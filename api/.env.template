# Highnote API key (from dashboard.highnote.com)
HIGHNOTE_API_KEY=sk_test_...

# Highnote environment: "test" or "live"
HIGHNOTE_ENVIRONMENT=test

# Card product ID to use for applications
HIGHNOTE_CARD_PRODUCT_ID=cp_...

# SQLite database path
DATABASE_URL=./data/highnote-demo.db

# Server port
PORT=3000

# Optional: JWT secret for signing auth tokens.
# - Local dev: leave unset; a per-process random secret is generated.
# - Production: required (set explicitly, or use Render's `generateValue`).
# JWT_SECRET=

# Optional: public URL for webhook auto-registration.
# - On Render: leave unset; RENDER_EXTERNAL_URL is auto-detected.
# - For local dev with ngrok: set to your tunnel URL, e.g. https://abc123.ngrok.io
# - When unset (and not on Render): auto-registration is skipped.
# WEBHOOK_PUBLIC_URL=
